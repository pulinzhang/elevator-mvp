{
  "name": "elevator-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
      "deploy": "npm run build && npx @cloudflare/next-on-pages && npx wrangler pages project create elevator-mvp --commit-message='Deploy elevator-mvp' 2>/dev/null || true && npx wrangler pages deploy .vercel/output/static --project-name=elevator-mvp",
    "preview": "npx @cloudflare/next-on-pages --watch",
    "d1:local:create": "wrangler d1 create elevator-db --local",
    "d1:local:init": "wrangler d1 execute elevator-db --local --file=schema.sql",
    "d1:local:reset": "wrangler d1 execute elevator-db --local --file=schema.sql --force",
    "d1:remote:create": "wrangler d1 create elevator-db",
    "d1:remote:init": "wrangler d1 execute elevator-db --remote --file=schema.sql",
    "d1:remote:reset": "wrangler d1 execute elevator-db --remote --file=schema.sql --force"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.1",
    "esbuild": "^0.24.0",
    "next": "15.2.4",
    "react": "18.3.0",
    "react-dom": "18.3.0",
    "wrangler": "^4.68.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
